{
  "name": "fortisoar-widget-harness",
  "version": "0.1.0",
  "description": "Local dev harness for FortiSOAR 7.x AngularJS widgets: render in isolation, proxy /api/* to a real instance, package + install with one click.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:live": "jest -c jest.live.config.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:live": "E2E_LIVE=1 playwright test \"**/*[Ll]ive*.spec.js\"",
    "lint:testids": "node scripts/lint-testids.js fsrPlaybookBuilder",
    "lint:testids:all": "node scripts/lint-testids.js",
    "lint:angular": "node scripts/lint-angular.js fsrPlaybookBuilder",
    "lint:angular:all": "node scripts/lint-angular.js",
    "lint:js": "find -L $(for d in widgets-src examples; do [ -e \"$d\" ] && echo \"$d\"; done) -name '*.js' ! -name '*.min.js' -not -path '*/node_modules/*' -not -path '*/lib/*' -not -path '*/vendor/*' -print0 | xargs -0 -r oxlint -c .oxlintrc.json",
    "lint:eslint": "eslint --resolve-plugins-relative-to . --ext .js $(for d in widgets-src examples; do [ -e \"$d\" ] && echo \"$d\"; done)",
    "lint:eslint:ts": "eslint --config eslint.config.js server.ts harness.module.ts packager.ts lib scripts",
    "lint": "pnpm lint:js && pnpm lint:eslint && pnpm lint:eslint:ts && pnpm lint:testids && pnpm lint:angular",
    "widget": "node scripts/widget.js",
    "assets": "bash scripts/fetch-soar-assets.sh",
    "new-widget": "bash scripts/new-widget.sh",
    "login": "node scripts/widget.js login",
    "list": "node scripts/widget.js list",
    "remote-list": "node scripts/widget.js remote-list",
    "pull": "node scripts/widget.js pull",
    "ship": "node scripts/widget.js ship",
    "verify-remote": "node scripts/widget.js verify-remote"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.3"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/angular": "^1.8.9",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "angular": "1.8",
    "angular-mocks": "1.8",
    "eslint": "^8.57.1",
    "eslint-plugin-angular": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "monaco-editor": "0.47.0",
    "oxlint": "^1.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "packageManager": "pnpm@8.14.2",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
