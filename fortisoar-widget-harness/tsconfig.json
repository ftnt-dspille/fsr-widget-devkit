{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "angular"],
    "strict": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "lib/types.ts",
    "lib/soarEnv.ts",
    "lib/harnessUtils.ts",
    "lib/harnessDrawer.ts",
    "lib/harnessRender.ts",
    "lib/soarBrowser.ts",
    "lib/liveUiDriver.ts",
    "harness.module.ts",
    "packager.ts",
    "server.ts",
    "scripts/widget.ts",
    "scripts/widget-verify-remote.ts",
    "scripts/lint-angular.ts",
    "scripts/lint-testids.ts",
    "scripts/extract-templates.ts",
    "scripts/probe-bootstrap.ts",
    "scripts/drive-live-widget.ts",
    "scripts/introspect.ts",
    "scripts/introspect-gate.ts"
  ]
}
