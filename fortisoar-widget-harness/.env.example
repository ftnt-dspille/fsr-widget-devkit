# Copy to .env and fill in.  ->  cp .env.example .env
#
# Standardized on the fsr_core project's variable names so a single .env can
# drive both projects (the harness reads these via lib/soarEnv.js).

# Base URL of the real FortiSOAR instance. Scheme is optional (https:// is
# assumed) and a trailing slash is stripped. Point this at a TRUSTED LAB box —
# the proxy disables TLS verification and strips CSP. Never production.
FSR_BASE_URL=your-soar-host.example.com

# Optional non-standard port (overrides any port in FSR_BASE_URL).
FSR_PORT=

# Credentials used to fetch a JWT via POST /auth/authenticate.
# The server caches the token in memory, refreshes before expiry, and
# re-authenticates if a proxied request comes back 401.
#
# PASSWORD: prefer the OS keychain over plaintext here. Run
#   node scripts/widget.js login
# to store it (needs the optional @napi-rs/keyring dep), then delete the
# FSR_PASSWORD line below. Precedence is: env var > OS keychain > this file, so
# CI/Docker can still export FSR_PASSWORD.
FSR_USERNAME=
FSR_PASSWORD=

# Optional API key (preferred over user/pass where supported).
FSR_API_KEY=

# Local port for the harness. The `widget` CLI defaults its HARNESS_URL to this
# same port, so the two always agree. Open http://localhost:<PORT> after start.
PORT=4401
