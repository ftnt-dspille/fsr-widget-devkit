{
  "root": true,
  "env": { "browser": true, "es2021": true },
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "script" },
  "globals": { "angular": "readonly", "$": "readonly", "jQuery": "readonly" },
  "plugins": ["angular"],
  "ignorePatterns": [
    "**/*.min.js",
    "**/widgetAssets/js/lib/**",
    "**/vendor/**",
    "node_modules/**"
  ],
  "rules": {
    "angular/module-getter": "warn",
    "angular/module-setter": "warn",
    "angular/di-unused": "warn",
    "angular/on-watch": "warn",
    "angular/timeout-service": "warn",
    "angular/interval-service": "warn",
    "angular/window-service": "off",
    "angular/document-service": "off"
  }
}
